{
  "agents": {
    "PlannerAgent": {
      "name": "PlannerAgent"
    },
    "ResearchManagerAgent": {
      "name": "ResearchManagerAgent"
    },
    "SectionResearchAgent": {
      "name": "SectionResearchAgent"
    },
    "SynthesisAgent": {
      "name": "SynthesisAgent"
    },
    "VerifierAgent": {
      "name": "VerifierAgent"
    }
  },
  "host_context": {},
  "hosted_tools": {
    "openai.web_search": {
      "agent_configs": {
        "SectionResearchAgent": {
          "context_size": "high"
        }
      },
      "config": {
        "context_size": "medium"
      },
      "permissions": {
        "ResearchManagerAgent": "available",
        "SectionResearchAgent": "available",
        "VerifierAgent": "available"
      },
      "provider": "openai",
      "tool": "web_search"
    }
  },
  "output_types": {
    "CompendiumPayload": {
      "python": "compendiumscribe.research.agents_workflow.artifacts:CompendiumPayload"
    },
    "ResearchAgenda": {
      "python": "compendiumscribe.research.agents_workflow.artifacts:ResearchAgenda"
    },
    "ResearchPlan": {
      "python": "compendiumscribe.research.agents_workflow.artifacts:ResearchPlan"
    },
    "SectionResearchBrief": {
      "python": "compendiumscribe.research.agents_workflow.artifacts:SectionResearchBrief"
    },
    "VerificationReport": {
      "python": "compendiumscribe.research.agents_workflow.artifacts:VerificationReport"
    }
  },
  "prompts": {
    "PlannerAgent": {
      "path": "../prompts/planner_agent.prompt.md"
    },
    "ResearchManagerAgent": {
      "path": "../prompts/research_manager_agent.prompt.md"
    },
    "SectionResearchAgent": {
      "path": "../prompts/section_research_agent.prompt.md"
    },
    "SynthesisAgent": {
      "path": "../prompts/synthesis_agent.prompt.md"
    },
    "VerifierAgent": {
      "path": "../prompts/verifier_agent.prompt.md"
    }
  },
  "tools": {},
  "version": 2
}
